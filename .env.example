# ============================================================================
# DELIVERY ASSURANCE COPILOT - ENVIRONMENT CONFIGURATION EXAMPLE
# ============================================================================
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: .env is in .gitignore - keep actual secrets secure and NEVER commit them
# ============================================================================

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# LANGCHAIN & LANGSMITH CONFIGURATION (Optional - for LLM observability)
# ============================================================================
# Get your API key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=lsv2_pt_XXXXXXXXXXXXXXXXXXXXXXXX
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=delivery-assurance-copilot

# ============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# ============================================================================
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://copilot:password@postgres:5432/copilotdb

# Individual connection details (used by seed_data.py)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=copilot
DATABASE_PASSWORD=password
DATABASE_NAME=copilotdb

# ============================================================================
# CHROMADB VECTOR STORE CONFIGURATION
# ============================================================================
# Directory path where ChromaDB persists embeddings
CHROMA_PERSIST_DIR=/data/chroma

# ============================================================================
# EMBEDDING MODEL CONFIGURATION
# ============================================================================
# Using sentence-transformers model for document embeddings
EMBED_MODEL=all-MiniLM-L6-v2

# ============================================================================
# DOCUMENT CHUNKING CONFIGURATION
# ============================================================================
# Size of text chunks for embedding (characters)
CHUNK_SIZE=512
# Overlap between chunks (characters)
CHUNK_OVERLAP=50

# ============================================================================
# RAG RETRIEVAL CONFIGURATION
# ============================================================================
# Number of top similar documents to retrieve from vector store
TOP_K_RETRIEVAL=6

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
# Options: development, staging, production
ENVIRONMENT=development

# ============================================================================
# JIRA INTEGRATION CONFIGURATION
# ============================================================================
# Enable/disable Jira addon
JIRA_ADDON_ENABLED=true

# Your Jira username (email)
# Get from: https://id.atlassian.com/manage/profile
JIRA_USERNAME=your-email@example.com

# Your Jira API token (for authentication)
# Generate from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0XXXXXXXXXXXXXXXXXXXXXXXX

# Jira Cloud URL and Project Key (configured per-project via Streamlit UI)
# Example: JIRA_URL=https://your-company.atlassian.net
# Example: JIRA_PROJECT_KEY=TEST

# ============================================================================
# ENCRYPTION CONFIGURATION
# ============================================================================
# Fernet encryption key for securing Jira API tokens in database
# Generate a new key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in the REQUIRED values (marked with XXXX above):
#    - OPENAI_API_KEY (required for LLM operations)
#    - DATABASE_URL and connection details (required for persistence)
#    - ENCRYPTION_KEY (generate new or copy from existing setup)
#    - JIRA_USERNAME and JIRA_API_TOKEN (if using Jira integration)
#
# 3. For development with Docker Compose:
#    docker-compose up
#
# 4. For production, ensure secure credential management:
#    - Use environment variables or secrets manager (AWS Secrets, Azure KeyVault, etc.)
#    - Never commit .env to version control
#    - Rotate API keys regularly
# ============================================================================
